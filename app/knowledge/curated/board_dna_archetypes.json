{
  "schema_version": 1,
  "score_contract": {
    "poor": [1, 3],
    "moderate": [4, 6],
    "strong": [7, 8],
    "exceptional_or_specialised": [9, 10]
  },
  "metric_order": {
    "behaviour": ["paddle", "wave_entry", "speed_generation", "drive", "release", "hold", "forgiveness", "stability", "sensitivity", "projection", "pivot", "carve", "glide", "turning_radius"],
    "conditions": ["weak_waves", "average_waves", "powerful_waves", "beach_break", "point_break", "reef_break", "hollow_waves", "open_face"],
    "rider_fit": ["beginner", "progressing", "intermediate", "advanced", "expert", "low_paddle_strength", "high_paddle_strength"]
  },
  "transformation_rules": [
    {"match": ["low rocker", "flat rocker", "flatter rocker"], "effects": {"paddle": 1, "wave_entry": 1, "speed_generation": 1, "weak_waves": 2, "powerful_waves": -1, "hollow_waves": -1}},
    {"match": ["high rocker", "more rocker", "increased rocker"], "effects": {"sensitivity": 1, "hold": 1, "pivot": 1, "powerful_waves": 1, "hollow_waves": 2, "weak_waves": -2, "paddle": -1}},
    {"match": ["full rails", "fuller rails", "boxy rails"], "effects": {"forgiveness": 1, "stability": 1, "sensitivity": -1}},
    {"match": ["refined rails", "low rails", "thin rails", "foiled rails"], "effects": {"hold": 1, "sensitivity": 2, "forgiveness": -1, "stability": -1}},
    {"match": ["parallel outline", "straighter outline", "wide outline"], "effects": {"speed_generation": 1, "drive": 1, "stability": 1, "turning_radius": 1, "pivot": -1}},
    {"match": ["round pin", "rounded pin", "pin tail"], "effects": {"hold": 2, "drive": 1, "powerful_waves": 1, "hollow_waves": 1, "release": -1}},
    {"match": ["swallow tail", "swallow"], "effects": {"speed_generation": 1, "release": 1, "drive": 1}},
    {"match": ["long rail", "longer rail", "long rail line"], "effects": {"paddle": 1, "glide": 2, "drive": 1, "point_break": 1, "turning_radius": 1}},
    {"match": ["wide nose", "full nose", "foam under the chest", "paddle power"], "effects": {"paddle": 2, "wave_entry": 1, "stability": 1, "low_paddle_strength": 1}},
    {"match": ["deep concave", "single concave"], "effects": {"speed_generation": 1, "projection": 1}},
    {"match": ["vee", "v out the tail", "v through the tail"], "effects": {"release": 1, "carve": 1}},
    {"match": ["channels", "channel bottom"], "effects": {"drive": 1, "hold": 1, "projection": 1}}
  ],
  "model_overrides": {
    "channel-islands::sampler": {
      "public_family": "daily_driver",
      "notes": ["Reviewed public-family correction: Sampler is a hybrid shortboard, not a fish."]
    },
    "lost::el-patron": {
      "public_family": "step_up",
      "notes": ["Task-approved public family governance: El Patron is published in Step Ups."]
    }
  },
